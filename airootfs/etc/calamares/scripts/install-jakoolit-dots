#!/bin/bash
# Script to install JaKooLit Hyprland Dotfiles
# This script runs from the LIVE system (dontChroot context)
# and installs dotfiles to the TARGET system

ROOT_MOUNT="$1"
USERNAME="$2"

if [ -z "$ROOT_MOUNT" ] || [ -z "$USERNAME" ]; then
    echo "Usage: $0 <root_mount> <username>"
    exit 1
fi

USER_HOME="${ROOT_MOUNT}/home/${USERNAME}"

# Check if Hyprland is installed in target system
if ! arch-chroot "$ROOT_MOUNT" pacman -Qi hyprland &>/dev/null; then
    echo "Hyprland not installed, skipping dotfiles installation"
    exit 0
fi

echo "Installing JaKooLit Hyprland Dotfiles for $USERNAME..."

# Clone the dotfiles repository to target system
if [ -d "${USER_HOME}/Hyprland-Dots" ]; then
    rm -rf "${USER_HOME}/Hyprland-Dots"
fi

git clone --depth=1 https://github.com/JaKooLit/Hyprland-Dots.git "${USER_HOME}/Hyprland-Dots"

# Fix ownership
arch-chroot "$ROOT_MOUNT" chown -R "${USERNAME}:${USERNAME}" "/home/${USERNAME}/Hyprland-Dots"

# Run the copy script in chroot as the user
arch-chroot "$ROOT_MOUNT" su - "$USERNAME" -c "cd ~/Hyprland-Dots && chmod +x copy.sh && ./copy.sh --no-confirm 2>/dev/null || ./copy.sh 2>/dev/null || true"

# If copy.sh doesn't work, manually copy config files
if [ -d "${USER_HOME}/Hyprland-Dots/config" ]; then
    echo "Manually copying config files..."
    mkdir -p "${USER_HOME}/.config"
    cp -r "${USER_HOME}/Hyprland-Dots/config/"* "${USER_HOME}/.config/" 2>/dev/null || true
    arch-chroot "$ROOT_MOUNT" chown -R "${USERNAME}:${USERNAME}" "/home/${USERNAME}/.config"
fi

# Copy wallpapers if available
if [ -d "${USER_HOME}/Hyprland-Dots/assets/wallpapers" ]; then
    mkdir -p "${USER_HOME}/Pictures/wallpapers"
    cp -r "${USER_HOME}/Hyprland-Dots/assets/wallpapers/"* "${USER_HOME}/Pictures/wallpapers/" 2>/dev/null || true
    arch-chroot "$ROOT_MOUNT" chown -R "${USERNAME}:${USERNAME}" "/home/${USERNAME}/Pictures"
fi

# Cleanup
rm -rf "${USER_HOME}/Hyprland-Dots"

echo "JaKooLit Hyprland Dotfiles installed successfully!"
